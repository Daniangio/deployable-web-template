# Copy to .env for local development. Keep real secrets out of git.

COMPOSE_PROJECT_NAME=web-game-template-dev
APP_NAME=Deployable Web Game Template

# Published local ports.
FRONTEND_PORT=5173
BACKEND_PORT=8000
POSTGRES_PORT=5432
REDIS_PORT=6379
ADMINER_PORT=8081
REDIS_INSIGHT_PORT=5540

# Database.
POSTGRES_DB=game_template
POSTGRES_USER=game_template
POSTGRES_PASSWORD=game_template_dev_password
DATABASE_URL=postgresql+psycopg://game_template:game_template_dev_password@postgres:5432/game_template

# Redis.
REDIS_PASSWORD=
REDIS_URL=redis://redis:6379/0
REDIS_INSIGHT_ENCRYPTION_KEY=local-dev-only-change-me

# Backend auth/session.
SECRET_KEY=replace-with-a-local-random-secret
ACCESS_TOKEN_EXPIRE_MINUTES=1440
AUTO_CREATE_SCHEMA=true
CORS_ALLOW_ORIGINS=*

# Firebase Admin SDK. Put the JSON file under secrets/ and keep it untracked.
FIREBASE_ADMIN_CREDENTIALS=secrets/firebase-admin.dev.json
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIMARY_ADMIN_EMAIL=admin@example.com

# Firebase Web SDK. These are public Firebase app identifiers, but project-specific.
VITE_FIREBASE_API_KEY=replace-me
VITE_FIREBASE_AUTH_DOMAIN=your-firebase-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_APP_ID=replace-me
VITE_FIREBASE_MESSAGING_SENDER_ID=replace-me
VITE_FIREBASE_STORAGE_BUCKET=your-firebase-project-id.firebasestorage.app

# Browser-to-backend URLs used by Vite.
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# Global chat.
CHAT_STREAM_PREFIX=chat
CHAT_RETENTION_SECONDS=86400
CHAT_HISTORY_LIMIT=80
