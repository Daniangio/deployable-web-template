# Production deployment example. Store the real file as /opt/web-game-template/.env.

APP_DOMAIN=game.example.com
APP_NAME=Deployable Web Game Template

POSTGRES_DB=game_template
POSTGRES_USER=game_template
POSTGRES_PASSWORD=replace-with-a-long-random-password

BACKEND_IMAGE=ghcr.io/your-github-owner/web-game-template-backend:latest
FRONTEND_IMAGE=ghcr.io/your-github-owner/web-game-template-frontend:latest

SECRET_KEY=replace-with-a-long-random-secret
CORS_ALLOW_ORIGINS=*

FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_PRIMARY_ADMIN_EMAIL=admin@example.com
FIREBASE_ADMIN_CREDENTIALS=/opt/web-game-template/secrets/firebase-admin.prod.json

# Redis authentication is recommended in production.
REDIS_PASSWORD=replace-with-a-long-random-redis-password
REDIS_URL=redis://:replace-with-a-long-random-redis-password@redis:6379/0

# Optional RedisInsight, enabled with `docker compose --profile ops up -d`.
REDIS_INSIGHT_PORT=5540
REDIS_INSIGHT_ENCRYPTION_KEY=replace-with-a-long-random-redisinsight-key

# Global chat.
CHAT_STREAM_PREFIX=chat
CHAT_RETENTION_SECONDS=86400
CHAT_HISTORY_LIMIT=80
