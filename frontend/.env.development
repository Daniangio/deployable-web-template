# Optional when running `npm run dev` from frontend/ without Docker.
# Docker Compose passes these from the root .env file.
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
VITE_FIREBASE_API_KEY=replace-me
VITE_FIREBASE_AUTH_DOMAIN=your-firebase-project-id.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-firebase-project-id
VITE_FIREBASE_APP_ID=replace-me
VITE_FIREBASE_MESSAGING_SENDER_ID=replace-me
VITE_FIREBASE_STORAGE_BUCKET=your-firebase-project-id.firebasestorage.app
